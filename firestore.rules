rules_version = '2';

// This app's Firebase client config is public (it ships in a static GitHub Pages
// bundle), so these rules are the only real access control. Every family member
// signs in anonymously on load; there's no per-user identity beyond "has an anon
// session", which is an intentionally low bar for a private single-family app.
service cloud.firestore {
  match /databases/{database}/documents {

    match /settings/main {
      allow read, write: if request.auth != null;
    }

    // recipeCache is normally written wholesale only by the Cloud Function's sync
    // (via the Admin SDK, which bypasses these rules entirely). The one exception:
    // the frontend's "on load" week-rollover pass updates each picked recipe's
    // lastCooked date directly (see docs/app.js + docs/firestore.js). Client
    // `update` is allowed for that; `create`/`delete` are reserved for the sync
    // function so a client can't wipe or fabricate the whole cache.
    match /recipeCache/main {
      allow read, update: if request.auth != null;
      allow create, delete: if false;
    }

    match /weekState/{weekKey} {
      allow read, write: if request.auth != null;
    }

    // History is append-only — each week's entry is written once during rollover
    // and never edited or removed afterward.
    match /history/{weekKey} {
      allow read, create: if request.auth != null;
      allow update, delete: if false;
    }
  }
}
