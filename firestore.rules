rules_version = '2';

// This app's Firebase client config is public (it ships in a static GitHub Pages
// bundle), so these rules are the only real access control. Every family member
// signs in anonymously on load; there's no per-user identity beyond "has an anon
// session", which is an intentionally low bar for a private single-family app.
service cloud.firestore {
  match /databases/{database}/documents {

    match /settings/main {
      allow read, write: if request.auth != null;
    }

    // recipeCache/main is seeded once at project setup and never recreated, so client
    // writes are always `update`s to that existing doc — adding a scraped recipe, or
    // the "on load" week-rollover pass updating a picked recipe's lastCooked date (see
    // docs/app.js + docs/firestore.js). `create`/`delete` stay blocked so a client can't
    // fabricate a fresh doc at this path or wipe the whole cache outright.
    match /recipeCache/main {
      allow read, update: if request.auth != null;
      allow create, delete: if false;
    }

    match /weekState/{weekKey} {
      allow read, write: if request.auth != null;
    }

    // History is append-only — each week's entry is written once during rollover
    // and never edited or removed afterward.
    match /history/{weekKey} {
      allow read, create: if request.auth != null;
      allow update, delete: if false;
    }
  }
}
